{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification",
      "human-gates"
    ],
    "reason": "The next system slice needs a reusable workflow plan consumed by V1/V2/V2.5 tooling, with resumable artifacts, adversarial review, and explicit human gates before runtime expansion."
  },
  "assumptions": [
    {
      "claim": "V2 remains the current execution boundary.",
      "verification": "Run V2 release checks and confirm V2 status still does not advance multi-slice workflows."
    },
    {
      "claim": "V2.5 review and repair artifacts can be modeled without changing V1 packet format.",
      "verification": "Review artifact schemas must bind to V1 run hashes and V2 attempt contracts without mutating V1/V2 artifacts."
    },
    {
      "claim": "V3 should consume only trusted V2.5 terminal states.",
      "verification": "V3 entry criteria must reject failed, invalid, review-pending, and changes-requested packet states."
    }
  ],
  "budget": {
    "file_touch_limit": "docs, scripts, fixtures, and generated out evidence only; no external repo edits",
    "max_agents": 5,
    "max_retries": 1,
    "max_rounds": 4,
    "time_box": "one release-candidate implementation sequence per version slice"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "V2.5 spec and workflow plan validate, docs link the plan, and the first implementation task list names fixtures and verification commands.",
      "expected_output": "docs/v2.5-review-repair-spec.md plus docs/v2.5-to-v3.workflow.plan.json and roadmap links",
      "forbidden_actions": [
        "runtime execution beyond first-slice adapter",
        "merge or push",
        "dependency installation",
        "secret access",
        "external messages",
        "history rewrite",
        "production deploy"
      ],
      "inputs": [
        "repository path",
        "docs/automation-roadmap.md",
        "docs/v2-execution-adapter-spec.md",
        "references/workflow-plan-schema.md",
        "references/workflow-patterns.md"
      ],
      "instruction": "Design the V2.5 execute-review-repair loop and V3 handoff without implementing a full multi-slice runtime."
    },
    "mode": "direct-codex"
  },
  "handoffs": [
    {
      "artifact": "docs/v2.5-review-repair-spec.md",
      "artifact_schema": {
        "format": "markdown",
        "required_fields": [
          "purpose",
          "command contract",
          "evidence model",
          "review artifact contract",
          "repair policy",
          "status model",
          "fixtures",
          "release criteria",
          "v3 handoff"
        ],
        "validation_command": "python scripts/check_release_text.py ."
      },
      "from_phase": "v25_design",
      "to_phase": "v25_contract_review"
    },
    {
      "artifact": "review-ledger.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "review_id",
          "source_attempt_id",
          "findings",
          "verdict",
          "source_hashes"
        ],
        "validation_command": "python -m json.tool review-ledger.json"
      },
      "from_phase": "v25_contract_review",
      "to_phase": "v25_repair_prepare"
    },
    {
      "artifact": "repair-attempt.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "repair_id",
          "source_review_id",
          "allowed_findings",
          "status",
          "verification"
        ],
        "validation_command": "python -m json.tool repair-attempt.json"
      },
      "from_phase": "v25_repair_prepare",
      "to_phase": "v3_entry_design"
    },
    {
      "artifact": "v3-entry-contract.md",
      "artifact_schema": {
        "format": "markdown",
        "required_fields": [
          "accepted v2.5 terminal states",
          "rejected states",
          "packet advancement input hashes",
          "human gate behavior"
        ],
        "validation_command": "python scripts/check_release_text.py ."
      },
      "from_phase": "v3_entry_design",
      "to_phase": "v3_runtime_backlog"
    }
  ],
  "objective": "Design and execute the next workflow from V2 release candidate toward practical large-task automation by adding a V2.5 execute-review-repair loop and a V3 handoff contract.",
  "parallelism": {
    "barriers": [
      "V2.5 contract must be reviewed before repair implementation",
      "V2.5 trusted terminal state must exist before V3 runtime entry design"
    ],
    "concurrency_cap": 3,
    "fan_in_rule": "Fan in after reviewer findings, fixture requirements, and status-model checks agree on the release boundary.",
    "shape": "hybrid"
  },
  "patterns": [
    "Sequential",
    "Adversarial Verify",
    "Loop Until Dry",
    "Human Gate",
    "Resume And Cache"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "V2 release candidate artifacts are present",
        "automation roadmap exists"
      ],
      "exit_criteria": [
        "V2.5 spec defines review, repair, evidence, fixtures, and release criteria"
      ],
      "id": "v25_design",
      "name": "V2.5 contract design",
      "outputs": [
        "docs/v2.5-review-repair-spec.md",
        "docs/v2.5-to-v3.workflow.plan.json"
      ],
      "worker_ids": [
        "workflow-architect"
      ]
    },
    {
      "depends_on": [
        "v25_design"
      ],
      "entry_criteria": [
        "V2.5 spec exists",
        "workflow plan validates against V0.5 schema"
      ],
      "exit_criteria": [
        "review findings are confirmed, refuted, or marked needs-human"
      ],
      "id": "v25_contract_review",
      "name": "Adversarial contract review",
      "outputs": [
        "review-ledger.json"
      ],
      "worker_ids": [
        "evidence-reviewer",
        "safety-reviewer"
      ]
    },
    {
      "depends_on": [
        "v25_contract_review"
      ],
      "entry_criteria": [
        "review verdict allows bounded repair",
        "risk gates are not blocked"
      ],
      "exit_criteria": [
        "repair attempt evidence is append-only and verification status is derived from evidence"
      ],
      "id": "v25_repair_prepare",
      "name": "Bounded repair implementation",
      "outputs": [
        "repair-attempt.json",
        "fixtures/v2.5/manifest.json",
        "docs/v2.5-decision.md"
      ],
      "worker_ids": [
        "repair-implementer"
      ]
    },
    {
      "depends_on": [
        "v25_repair_prepare"
      ],
      "entry_criteria": [
        "V2.5 terminal state is review-approved or repair-verified; needs-human remains rejected until a later human-override contract"
      ],
      "exit_criteria": [
        "V3 entry contract defines packet advancement inputs and rejected states"
      ],
      "id": "v3_entry_design",
      "name": "V3 runtime entry contract",
      "outputs": [
        "v3-entry-contract.md"
      ],
      "worker_ids": [
        "runtime-architect"
      ]
    },
    {
      "depends_on": [
        "v3_entry_design"
      ],
      "entry_criteria": [
        "V3 entry contract exists",
        "V2.5 terminal state policy is explicit"
      ],
      "exit_criteria": [
        "runtime backlog lists V3 implementation slices without executing them"
      ],
      "id": "v3_runtime_backlog",
      "name": "V3 runtime backlog",
      "outputs": [
        "runtime-backlog.md"
      ],
      "worker_ids": [
        "runtime-architect"
      ]
    }
  ],
  "plan_id": "v2.5-to-v3-automation-workflow",
  "resume": {
    "cacheable_outputs": [
      "docs/v2.5-review-repair-spec.md",
      "docs/v2.5-to-v3.workflow.plan.json",
      "review-ledger.json",
      "repair-attempt.json",
      "v3-entry-contract.md"
    ],
    "invalidators": [
      "V2 artifact contract changes",
      "V1 compiler status model changes",
      "workflow plan schema changes",
      "risk gate vocabulary changes",
      "review or repair contract ledger mismatch"
    ],
    "restart_points": [
      "v25_design",
      "v25_contract_review",
      "v25_repair_prepare",
      "v3_entry_design"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before writing implementation files and ask for approval",
      "trigger": "write action"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before shell use and ask for approval",
      "trigger": "shell process"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before network use and ask for approval",
      "trigger": "network action"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before dependency installs and ask for approval",
      "trigger": "dependency install"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before public API changes and ask for approval",
      "trigger": "public API change"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before external messages and ask for approval",
      "trigger": "external message"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before history rewrite and ask for approval",
      "trigger": "history rewrite"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Design the next workflow after the V2 execution adapter so the system can move toward full large-task automation.",
  "surfaces": [
    {
      "access_mode": "write-proposed",
      "id": "skill-repo",
      "kind": "repo",
      "locator": "."
    },
    {
      "access_mode": "write-proposed",
      "id": "roadmap",
      "kind": "artifact",
      "locator": "docs/automation-roadmap.md"
    },
    {
      "access_mode": "write-proposed",
      "id": "v2-adapter",
      "kind": "artifact",
      "locator": "scripts/execute_packet.py"
    },
    {
      "access_mode": "write-proposed",
      "id": "v2-spec",
      "kind": "artifact",
      "locator": "docs/v2-execution-adapter-spec.md"
    }
  ],
  "verification": [
    {
      "claim_or_output": "The V2.5 plan is machine-readable and schema-valid.",
      "evidence_required": [
        "python scripts/evaluate_plan.py --plan docs/v2.5-to-v3.workflow.plan.json"
      ],
      "falsifier": "The evaluator rejects the workflow plan or produces a downgrade artifact."
    },
    {
      "claim_or_output": "The V2.5 spec does not overclaim full runtime behavior.",
      "evidence_required": [
        "docs/v2.5-review-repair-spec.md",
        "docs/automation-roadmap.md"
      ],
      "falsifier": "The docs claim packet advancement, parallel orchestration, merge, push, deploy, or full large-task completion in V2.5."
    },
    {
      "claim_or_output": "The workflow has safe gates for risky actions.",
      "evidence_required": [
        "risk_gates",
        "forbidden_actions",
        "human gate defaults"
      ],
      "falsifier": "A worker can perform write, shell, network, dependency, public API, external message, or history rewrite actions without a gate."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 9000,
        "must_exclude": [
          "unrelated generated out directories",
          "secret values"
        ],
        "must_include": [
          "docs/automation-roadmap.md",
          "docs/v2-execution-adapter-spec.md",
          "references/workflow-plan-schema.md",
          "references/workflow-patterns.md"
        ]
      },
      "forbidden_actions": [
        "implementing runtime behavior before spec approval",
        "installing dependencies",
        "pushing or merging"
      ],
      "id": "workflow-architect",
      "ownership": [
        "V2.5 spec",
        "V3 handoff boundaries",
        "workflow plan"
      ],
      "prompt_contract": {
        "inputs": [
          "current roadmap",
          "V2 spec",
          "workflow plan schema"
        ],
        "required_output_schema": "markdown spec plus schema-valid workflow.plan.json",
        "stop_conditions": [
          "V2 artifact contract is unclear",
          "workflow schema validation fails repeatedly"
        ]
      },
      "role": "Workflow architect",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [
          "network",
          "external-message",
          "shell",
          "write"
        ],
        "shell": true,
        "write": true
      }
    },
    {
      "context_budget": {
        "max_files": 15,
        "max_tokens": 8000,
        "must_exclude": [
          "implementation preferences without evidence"
        ],
        "must_include": [
          "V2.5 spec",
          "V2 evidence contract",
          "fixture list"
        ]
      },
      "forbidden_actions": [
        "rubber-stamping claims",
        "editing source files"
      ],
      "id": "evidence-reviewer",
      "ownership": [
        "review artifact schema",
        "tamper invalidation",
        "status derivation"
      ],
      "prompt_contract": {
        "inputs": [
          "V2.5 spec",
          "V2 adapter evidence model"
        ],
        "required_output_schema": "review-ledger.json with confirmed, refuted, and unresolved findings",
        "stop_conditions": [
          "review target lacks source hashes",
          "finding cannot be falsified"
        ]
      },
      "role": "Evidence reviewer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [
          "write",
          "network",
          "external-message"
        ],
        "shell": false,
        "write": false
      }
    },
    {
      "context_budget": {
        "max_files": 15,
        "max_tokens": 8000,
        "must_exclude": [
          "unsafe backend assumptions"
        ],
        "must_include": [
          "risk gates",
          "backend policies",
          "repair policy"
        ]
      },
      "forbidden_actions": [
        "approving destructive repair by default",
        "weakening human gates"
      ],
      "id": "safety-reviewer",
      "ownership": [
        "risk gates",
        "human approval defaults",
        "repair refusal modes"
      ],
      "prompt_contract": {
        "inputs": [
          "V2.5 spec",
          "risk vocabulary"
        ],
        "required_output_schema": "safety findings with gated action, safe default, and release impact",
        "stop_conditions": [
          "risk action lacks a safe default"
        ]
      },
      "role": "Safety reviewer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [
          "write",
          "shell",
          "network",
          "external-message"
        ],
        "shell": false,
        "write": false
      }
    },
    {
      "context_budget": {
        "max_files": 25,
        "max_tokens": 10000,
        "must_exclude": [
          "unreviewed broad refactors"
        ],
        "must_include": [
          "review-ledger.json",
          "V2.5 spec",
          "target source files"
        ]
      },
      "forbidden_actions": [
        "repairing findings that are not allowed",
        "rewriting prior evidence",
        "merging or pushing"
      ],
      "id": "repair-implementer",
      "ownership": [
        "bounded repair patch",
        "repair evidence",
        "retry cap"
      ],
      "prompt_contract": {
        "inputs": [
          "review-ledger.json",
          "allowed findings",
          "current V2.5 artifacts"
        ],
        "required_output_schema": "repair-attempt.json plus patch/evidence references",
        "stop_conditions": [
          "finding requires a blocked risk gate",
          "retry cap reached"
        ]
      },
      "role": "Repair implementer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [
          "network",
          "external-message",
          "shell",
          "write"
        ],
        "shell": true,
        "write": true
      }
    },
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 8000,
        "must_exclude": [
          "implementation details not needed for packet advancement"
        ],
        "must_include": [
          "V2.5 terminal states",
          "resume contract",
          "risk gates"
        ]
      },
      "forbidden_actions": [
        "implementing V3 before V2.5 terminal states exist",
        "skipping human gates"
      ],
      "id": "runtime-architect",
      "ownership": [
        "V3 entry criteria",
        "packet advancement contract",
        "runtime backlog"
      ],
      "prompt_contract": {
        "inputs": [
          "V2.5 terminal states",
          "repair status",
          "original workflow plan"
        ],
        "required_output_schema": "v3-entry-contract.md with accepted states, rejected states, hashes, and resume behavior",
        "stop_conditions": [
          "V2.5 status is invalid or failed"
        ]
      },
      "role": "Runtime architect",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [
          "write",
          "shell",
          "network",
          "external-message"
        ],
        "shell": false,
        "write": true
      }
    }
  ]
}
