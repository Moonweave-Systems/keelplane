{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification"
    ],
    "reason": "The V6.5 dispatch needs a controlled result adapter before release_decision can later be reviewed and ingested."
  },
  "assumptions": [
    {
      "claim": "The first controlled next-phase worker can be represented by a deterministic fixture.",
      "verification": "Run only an allowlisted fixture that writes release-decision.md under owned out/v7 work."
    },
    {
      "claim": "V6.5 dispatch lineage is enough to bind the result to the selected frontier packet.",
      "verification": "Resume V6.5 dispatch and hash dispatch, packet, prompt, stdout, stderr, and produced outputs."
    }
  ],
  "budget": {
    "file_touch_limit": "one new script plus V7 docs and roadmap updates",
    "max_agents": 1,
    "max_retries": 1,
    "max_rounds": 1,
    "time_box": "one implementation slice"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "out/v7/v32-semantic-dogfood/status.json reports executed and resume_state resumable",
      "expected_output": "release-decision.md produced under owned out/v7 work directory",
      "forbidden_actions": [
        "arbitrary worker execution",
        "backend execution",
        "external service calls",
        "repository writes"
      ],
      "inputs": [
        "workflow.plan.json",
        "original prompt",
        "repository path",
        "out/v6.5/v32-semantic-dogfood"
      ],
      "instruction": "Consume one V6.5 frontier dispatch and run only the allowlisted release-decision fixture in an owned work directory."
    },
    "mode": "direct-codex"
  },
  "handoffs": [
    {
      "artifact": "dispatch.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "status",
          "phase_id",
          "expected_outputs",
          "source_v6_run_path"
        ],
        "validation_command": "python -m json.tool dispatch.json"
      },
      "from_phase": "dispatch_validation",
      "to_phase": "fixture_execution"
    },
    {
      "artifact": "release-decision.md",
      "artifact_schema": {
        "format": "markdown",
        "required_fields": [
          "decision",
          "evidence",
          "next_workflow"
        ],
        "validation_command": "test -s release-decision.md"
      },
      "from_phase": "fixture_execution",
      "to_phase": "result_recording"
    }
  ],
  "objective": "Implement the first controlled worker-result adapter for V6.5 frontier dispatches, producing release-decision.md without arbitrary execution.",
  "parallelism": {
    "barriers": [
      "dispatch validation before fixture execution",
      "fixture execution before result recording"
    ],
    "concurrency_cap": 1,
    "fan_in_rule": "No fan-in in the first slice; one dispatch result is recorded.",
    "shape": "pipeline"
  },
  "patterns": [
    "Sequential",
    "Resume And Cache",
    "Adversarial Verify"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "V6.5 dispatch is owned",
        "V6.5 resume is clean"
      ],
      "exit_criteria": [
        "dispatch phase is release_decision",
        "expected output is release-decision.md"
      ],
      "id": "dispatch_validation",
      "name": "Dispatch Validation",
      "outputs": [
        "dispatch.json"
      ],
      "worker_ids": [
        "frontier-result-worker"
      ]
    },
    {
      "depends_on": [
        "dispatch_validation"
      ],
      "entry_criteria": [
        "dispatch validates"
      ],
      "exit_criteria": [
        "release-decision.md exists under owned work directory"
      ],
      "id": "fixture_execution",
      "name": "Fixture Execution",
      "outputs": [
        "release-decision.md"
      ],
      "worker_ids": [
        "frontier-result-worker"
      ]
    },
    {
      "depends_on": [
        "fixture_execution"
      ],
      "entry_criteria": [
        "fixture output exists"
      ],
      "exit_criteria": [
        "result.json and hashes.json bind the output",
        "resume detects output tampering"
      ],
      "id": "result_recording",
      "name": "Result Recording",
      "outputs": [
        "result.json",
        "hashes.json",
        "status.json",
        "resume.md"
      ],
      "worker_ids": [
        "frontier-result-worker"
      ]
    }
  ],
  "plan_id": "v7-controlled-frontier-result-first-slice",
  "resume": {
    "cacheable_outputs": [
      "release-decision.md",
      "result.json",
      "hashes.json",
      "status.json",
      "resume.md"
    ],
    "invalidators": [
      "V6.5 dispatch changes",
      "dispatch packet or prompt changes",
      "stdout or stderr sidecar changes",
      "produced output changes",
      "result or hashes tampering"
    ],
    "restart_points": [
      "dispatch_validation",
      "fixture_execution",
      "result_recording"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before arbitrary worker execution, preserve completed evidence, and ask for approval",
      "trigger": "worker or backend execution"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before shell command execution outside allowlisted fixture and ask for approval",
      "trigger": "shell command execution"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before writing outside owned work directories and ask for approval",
      "trigger": "write access"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Proceed with the next workflow after V6.5 frontier dispatch.",
  "surfaces": [
    {
      "access_mode": "write-approved",
      "id": "repo",
      "kind": "repo",
      "locator": "."
    },
    {
      "access_mode": "read-only",
      "id": "v65-dispatch",
      "kind": "artifact",
      "locator": "out/v6.5/v32-semantic-dogfood"
    }
  ],
  "verification": [
    {
      "claim_or_output": "V7 consumes only trusted V6.5 dispatches.",
      "evidence_required": [
        "scripts/run_frontier_result.py --self-test",
        "out/v7/v32-semantic-dogfood/status.json"
      ],
      "falsifier": "A stale or tampered V6.5 dispatch can produce executed status."
    },
    {
      "claim_or_output": "V7 does not write to the repository or run arbitrary backends.",
      "evidence_required": [
        "out/v7/v32-semantic-dogfood/work/release-decision.md",
        "out/v7/v32-semantic-dogfood/result.json"
      ],
      "falsifier": "The fixture writes outside owned out/v7 work or accepts arbitrary commands."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 16000,
        "must_exclude": [
          "out/**/work/"
        ],
        "must_include": [
          "scripts/dispatch_frontier.py",
          "scripts/run_frontier_result.py",
          "docs/v7-controlled-frontier-result.workflow.plan.json"
        ]
      },
      "forbidden_actions": [
        "arbitrary worker execution",
        "backend execution",
        "external service calls",
        "repository writes"
      ],
      "id": "frontier-result-worker",
      "ownership": [
        "dispatch_validation",
        "fixture_execution",
        "result_recording"
      ],
      "prompt_contract": {
        "inputs": [
          "V6.5 dispatch directory",
          "dispatch packet",
          "dispatch prompt"
        ],
        "required_output_schema": "result.json plus release-decision.md",
        "stop_conditions": [
          "dispatch is not prepared",
          "expected output is not release-decision.md",
          "arbitrary execution would be required"
        ]
      },
      "role": "Controlled frontier result implementer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": true,
        "write": true
      }
    }
  ]
}
