{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification",
      "human-gates"
    ],
    "reason": "The request defines DWM's large-work control contract and must produce executable artifacts, fixtures, contract checks, and resumable evidence."
  },
  "assumptions": [
    {
      "claim": "The user's six concerns can be represented as measurable workflow control signals.",
      "verification": "Fixture coverage must include a fully controlled workflow and blocked workflows with missing direction or overclaim signals."
    },
    {
      "claim": "This slice does not require destructive execution or external publication.",
      "verification": "Risk gates forbid production, networked adapter execution, dependency install, secret access, history rewrite, and external benchmark claims."
    }
  ],
  "budget": {
    "file_touch_limit": "12 files",
    "max_agents": 1,
    "max_retries": 1,
    "max_rounds": 1,
    "time_box": "one large-workflow control slice"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "python scripts/dwm_large_workflow_control.py --self-test && python scripts/dwm_large_workflow_control.py --manifest fixtures/v73/manifest.json --out out/large-workflow-control/v73-final && python scripts/evaluate_plan.py --plan docs/v73-large-workflow-control.workflow.plan.json && python scripts/check_contract.py --self-test",
      "expected_output": "V73 control evaluator, fixtures, spec, blueprint, workflow plan JSON, decision doc, and passing verification",
      "forbidden_actions": [
        "edit docs/spec.md without reconciling existing user changes",
        "publish public benchmark claims",
        "install dependencies",
        "access secrets",
        "rewrite git history"
      ],
      "inputs": [
        "repository path",
        "user six-axis objective",
        "references/workflow-plan-schema.md",
        "scripts/dwm.py",
        "scripts/check_contract.py"
      ],
      "instruction": "Implement the V73 six-axis large-workflow control evaluator, fixture suite, spec, blueprint, workflow plan, and release contract integration without touching unrelated dirty files."
    },
    "mode": "direct-codex"
  },
  "handoffs": [
    {
      "artifact": "control-contract.md",
      "artifact_schema": {
        "format": "markdown",
        "required_fields": [
          "axis",
          "required signals",
          "blocker behavior"
        ],
        "validation_command": "python scripts/check_release_text.py ."
      },
      "from_phase": "axis_contract",
      "to_phase": "evaluator"
    },
    {
      "artifact": "control-artifacts.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "large-workflow-control.json",
          "status.json",
          "summary.json"
        ],
        "validation_command": "python scripts/dwm_large_workflow_control.py --self-test"
      },
      "from_phase": "evaluator",
      "to_phase": "fixture_gate"
    },
    {
      "artifact": "fixture-summary.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "suite_id",
          "required_passed",
          "decision"
        ],
        "validation_command": "python scripts/dwm_large_workflow_control.py --manifest fixtures/v73/manifest.json --out out/large-workflow-control/v73-final"
      },
      "from_phase": "fixture_gate",
      "to_phase": "contract_release"
    }
  ],
  "objective": "Define and implement the six-axis control-plane gate that keeps large DWM workflows aligned with user intent, quality, efficiency, recovery, and evidence.",
  "parallelism": {
    "barriers": [
      "Do not publish public benchmark claims from V73 control scores."
    ],
    "concurrency_cap": 2,
    "fan_in_rule": "Contract integration starts only after evaluator and fixture outputs exist.",
    "shape": "pipeline"
  },
  "patterns": [
    "Sequential",
    "Pipeline",
    "Adversarial Verify",
    "Resume And Cache",
    "Human Gate"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "User's six evaluation concerns are available."
      ],
      "exit_criteria": [
        "Each axis has direction-neutral required signals and blocker behavior."
      ],
      "id": "axis_contract",
      "name": "Axis Contract",
      "outputs": [
        "control-contract.md"
      ],
      "worker_ids": [
        "control_designer"
      ]
    },
    {
      "depends_on": [
        "axis_contract"
      ],
      "entry_criteria": [
        "Axis contract exists."
      ],
      "exit_criteria": [
        "CLI writes JSON, markdown, status, and manifest summary artifacts."
      ],
      "id": "evaluator",
      "name": "Evaluator Implementation",
      "outputs": [
        "control-artifacts.json"
      ],
      "worker_ids": [
        "evaluator_builder"
      ]
    },
    {
      "depends_on": [
        "evaluator"
      ],
      "entry_criteria": [
        "Evaluator accepts workflow objects."
      ],
      "exit_criteria": [
        "Ready, missing-direction, and overclaim fixtures behave deterministically."
      ],
      "id": "fixture_gate",
      "name": "Fixture Gate",
      "outputs": [
        "fixture-summary.json"
      ],
      "worker_ids": [
        "fixture_verifier"
      ]
    },
    {
      "depends_on": [
        "fixture_gate"
      ],
      "entry_criteria": [
        "Fixture gate passes."
      ],
      "exit_criteria": [
        "Release commands, command reference, decision docs, and contract checks include V73."
      ],
      "id": "contract_release",
      "name": "Contract And Release Integration",
      "outputs": [
        "verification-log.md"
      ],
      "worker_ids": [
        "contract_reviewer"
      ]
    }
  ],
  "plan_id": "v73-large-workflow-control",
  "resume": {
    "cacheable_outputs": [
      "control-contract.md",
      "control-artifacts.json",
      "fixture-summary.json",
      "verification-log.md"
    ],
    "invalidators": [
      "axis semantics changed",
      "fixture schema changed",
      "release command count changed"
    ],
    "restart_points": [
      "axis_contract",
      "evaluator",
      "fixture_gate",
      "contract_release"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
