{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification"
    ],
    "reason": "V7 frontier results need deterministic review before runtime ingestion can treat release_decision as complete."
  },
  "assumptions": [
    {
      "claim": "A V7 executed result is not enough to complete a frontier phase.",
      "verification": "Require a V7.5 review artifact that recomputes V7 resume and output hashes before approval."
    },
    {
      "claim": "The V6.5 dispatch lineage is enough to bind the V7 result to the selected frontier packet.",
      "verification": "Follow V7 result metadata back to V6.5 dispatch and require clean V6.5 resume."
    }
  ],
  "budget": {
    "file_touch_limit": "one new script plus V7.5 docs, fixtures, and roadmap updates",
    "max_agents": 1,
    "max_retries": 1,
    "max_rounds": 1,
    "time_box": "one implementation slice"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "out/v7.5/v32-semantic-dogfood/status.json reports review-approved and resume_state resumable",
      "expected_output": "V7.5 review artifacts for release-decision.md",
      "forbidden_actions": [
        "runtime ingestion",
        "worker execution",
        "backend execution",
        "external service calls"
      ],
      "inputs": [
        "workflow.plan.json",
        "original prompt",
        "repository path",
        "out/v7/v32-semantic-dogfood"
      ],
      "instruction": "Consume one trusted V7 frontier result, review release-decision.md deterministically, and write review artifacts without runtime ingestion."
    },
    "mode": "direct-codex"
  },
  "handoffs": [
    {
      "artifact": "result.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "status",
          "phase_id",
          "produced_outputs",
          "source_dispatch_path"
        ],
        "validation_command": "python -m json.tool result.json"
      },
      "from_phase": "result_validation",
      "to_phase": "lineage_validation"
    },
    {
      "artifact": "review.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "verdict",
          "source_result_path",
          "source_phase_id",
          "approved_outputs"
        ],
        "validation_command": "python -m json.tool review.json"
      },
      "from_phase": "deterministic_review",
      "to_phase": "resume_verification"
    }
  ],
  "objective": "Design the first V7.5 frontier-result review slice that consumes V7 evidence and produces a trusted review artifact before any runtime ingestion.",
  "parallelism": {
    "barriers": [
      "result validation before lineage validation",
      "lineage validation before deterministic review",
      "deterministic review before resume verification"
    ],
    "concurrency_cap": 1,
    "fan_in_rule": "No fan-in in the first slice; one V7 result is reviewed at a time.",
    "shape": "pipeline"
  },
  "patterns": [
    "Sequential",
    "Resume And Cache",
    "Adversarial Verify"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "V7 result directory is owned",
        "V7 status is executed"
      ],
      "exit_criteria": [
        "result.json is valid",
        "release-decision.md is listed in produced outputs"
      ],
      "id": "result_validation",
      "name": "Result Validation",
      "outputs": [
        "result.json"
      ],
      "worker_ids": [
        "frontier-review-worker"
      ]
    },
    {
      "depends_on": [
        "result_validation"
      ],
      "entry_criteria": [
        "trusted result context exists"
      ],
      "exit_criteria": [
        "V6.5 dispatch source is recovered",
        "V6.5 resume is clean"
      ],
      "id": "lineage_validation",
      "name": "Lineage Validation",
      "outputs": [
        "lineage.json"
      ],
      "worker_ids": [
        "frontier-review-worker"
      ]
    },
    {
      "depends_on": [
        "lineage_validation"
      ],
      "entry_criteria": [
        "lineage validates"
      ],
      "exit_criteria": [
        "review.json records approve, request-changes, needs-human, or invalid",
        "review.md is derived from review.json"
      ],
      "id": "deterministic_review",
      "name": "Deterministic Review",
      "outputs": [
        "review.json",
        "review.md",
        "hashes.json"
      ],
      "worker_ids": [
        "frontier-review-worker"
      ]
    },
    {
      "depends_on": [
        "deterministic_review"
      ],
      "entry_criteria": [
        "review artifacts exist"
      ],
      "exit_criteria": [
        "resume recomputes the same review and hashes",
        "tampered review invalidates resume"
      ],
      "id": "resume_verification",
      "name": "Resume Verification",
      "outputs": [
        "status.json",
        "resume.md"
      ],
      "worker_ids": [
        "frontier-review-worker"
      ]
    }
  ],
  "plan_id": "v7.5-frontier-result-review-first-slice",
  "resume": {
    "cacheable_outputs": [
      "review.json",
      "review.md",
      "hashes.json",
      "status.json",
      "resume.md"
    ],
    "invalidators": [
      "V7 result status changes",
      "V7 result hash changes",
      "V7 stdout or stderr changes",
      "V7 produced output changes",
      "V6.5 dispatch source changes",
      "review or hashes tampering"
    ],
    "restart_points": [
      "result_validation",
      "lineage_validation",
      "deterministic_review",
      "resume_verification"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before runtime ingestion, preserve review artifacts, and ask for approval",
      "trigger": "runtime ingestion"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before worker execution and ask for approval",
      "trigger": "worker or backend execution"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before shell command execution and ask for approval",
      "trigger": "shell command execution"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before writing and ask for approval",
      "trigger": "write access"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Design the next workflow after V7 controlled frontier result.",
  "surfaces": [
    {
      "access_mode": "write-approved",
      "id": "repo",
      "kind": "repo",
      "locator": "."
    },
    {
      "access_mode": "read-only",
      "id": "v7-result",
      "kind": "artifact",
      "locator": "out/v7/v32-semantic-dogfood"
    },
    {
      "access_mode": "read-only",
      "id": "v65-dispatch",
      "kind": "artifact",
      "locator": "out/v6.5/v32-semantic-dogfood"
    }
  ],
  "verification": [
    {
      "claim_or_output": "V7.5 consumes only trusted V7 frontier results.",
      "evidence_required": [
        "scripts/review_frontier_result.py --self-test",
        "out/v7.5/v32-semantic-dogfood/status.json"
      ],
      "falsifier": "A stale or tampered V7 result can produce review-approved status."
    },
    {
      "claim_or_output": "V7.5 does not ingest runtime state or execute workers.",
      "evidence_required": [
        "out/v7.5/v32-semantic-dogfood/review.json",
        "out/v7.5/v32-semantic-dogfood/status.json"
      ],
      "falsifier": "The review command advances runtime state, dispatches work, or accepts arbitrary backend execution."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 16000,
        "must_exclude": [
          "out/**/work/"
        ],
        "must_include": [
          "scripts/run_frontier_result.py",
          "docs/v7-controlled-frontier-result-spec.md",
          "docs/v7.5-frontier-result-review-spec.md",
          "docs/v7.5-frontier-result-review.workflow.plan.json"
        ]
      },
      "forbidden_actions": [
        "runtime ingestion",
        "worker execution",
        "backend execution",
        "external service calls"
      ],
      "id": "frontier-review-worker",
      "ownership": [
        "result_validation",
        "lineage_validation",
        "deterministic_review",
        "resume_verification"
      ],
      "prompt_contract": {
        "inputs": [
          "V7 result directory",
          "V7 result metadata",
          "V6.5 dispatch lineage"
        ],
        "required_output_schema": "review.json plus status.json",
        "stop_conditions": [
          "V7 result is not executed",
          "V7 resume is not clean",
          "release-decision.md is missing",
          "runtime ingestion would be required"
        ]
      },
      "role": "Frontier result review implementer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": true,
        "write": true
      }
    }
  ]
}
