{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "resumable-handoffs",
      "adversarial-verification"
    ],
    "reason": "The V6 frontier needs a deterministic dispatch handoff before any later worker adapter can consume the next phase safely."
  },
  "assumptions": [
    {
      "claim": "A V6 selected frontier packet can be treated as the next dispatch source.",
      "verification": "Resume V6 and require the selected packet hash and prompt hash to match V6 status snapshots."
    },
    {
      "claim": "The first loop-back slice should not execute the frontier packet.",
      "verification": "The dispatch artifact is emit-only and includes explicit stop conditions."
    }
  ],
  "budget": {
    "file_touch_limit": "one new script plus V6.5 docs and roadmap updates",
    "max_agents": 1,
    "max_retries": 1,
    "max_rounds": 1,
    "time_box": "one implementation slice"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "out/v6.5/v32-semantic-dogfood/status.json reports prepared and resume_state resumable",
      "expected_output": "V6.5 frontier dispatch bundle for release_decision",
      "forbidden_actions": [
        "worker execution",
        "backend execution",
        "runtime advancement without reviewed evidence",
        "external service calls"
      ],
      "inputs": [
        "workflow.plan.json",
        "original prompt",
        "repository path",
        "out/v6/v32-semantic-dogfood"
      ],
      "instruction": "Consume one V6 frontier packet and emit a deterministic dispatch bundle without executing it."
    },
    "mode": "direct-codex"
  },
  "handoffs": [
    {
      "artifact": "state.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "completed_phase_ids",
          "selected_phase_ids",
          "packet_hashes",
          "prompt_hashes"
        ],
        "validation_command": "python -m json.tool state.json"
      },
      "from_phase": "frontier_validation",
      "to_phase": "dispatch_preparation"
    },
    {
      "artifact": "dispatch.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "status",
          "source_v6_run_path",
          "source_packet_path",
          "packet_id",
          "phase_id"
        ],
        "validation_command": "python -m json.tool dispatch.json"
      },
      "from_phase": "dispatch_preparation",
      "to_phase": "resume_verification"
    }
  ],
  "objective": "Implement the first loop-back slice that turns a trusted V6 frontier packet into an owned dispatch bundle for the next phase without executing workers.",
  "parallelism": {
    "barriers": [
      "frontier validation before dispatch preparation"
    ],
    "concurrency_cap": 1,
    "fan_in_rule": "No fan-in in the first slice; one selected frontier packet is dispatched.",
    "shape": "pipeline"
  },
  "patterns": [
    "Sequential",
    "Resume And Cache",
    "Human Gate"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "V6 output directory is owned",
        "V6 resume is clean"
      ],
      "exit_criteria": [
        "selected frontier packet exists",
        "packet and prompt match V6 snapshots"
      ],
      "id": "frontier_validation",
      "name": "Frontier Validation",
      "outputs": [
        "state.json"
      ],
      "worker_ids": [
        "frontier-dispatch-worker"
      ]
    },
    {
      "depends_on": [
        "frontier_validation"
      ],
      "entry_criteria": [
        "frontier packet validates"
      ],
      "exit_criteria": [
        "dispatch.json is prepared",
        "packet.json and prompt.md are copied"
      ],
      "id": "dispatch_preparation",
      "name": "Dispatch Preparation",
      "outputs": [
        "dispatch.json",
        "packet.json",
        "prompt.md",
        "hashes.json"
      ],
      "worker_ids": [
        "frontier-dispatch-worker"
      ]
    },
    {
      "depends_on": [
        "dispatch_preparation"
      ],
      "entry_criteria": [
        "dispatch bundle exists"
      ],
      "exit_criteria": [
        "resume recomputes dispatch and hashes",
        "tampered packet invalidates resume"
      ],
      "id": "resume_verification",
      "name": "Resume Verification",
      "outputs": [
        "status.json",
        "resume.md"
      ],
      "worker_ids": [
        "frontier-dispatch-worker"
      ]
    }
  ],
  "plan_id": "v65-frontier-dispatch-first-slice",
  "resume": {
    "cacheable_outputs": [
      "dispatch.json",
      "packet.json",
      "prompt.md",
      "hashes.json",
      "status.json",
      "resume.md"
    ],
    "invalidators": [
      "V6 status changes",
      "V6 state changes",
      "frontier packet changes",
      "frontier prompt changes",
      "dispatch artifact tampering"
    ],
    "restart_points": [
      "frontier_validation",
      "dispatch_preparation",
      "resume_verification"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before worker execution, preserve dispatch artifacts, and ask for approval",
      "trigger": "worker or backend execution"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before writing outside approved script and docs scope, preserve completed evidence, and ask for approval",
      "trigger": "write access"
    },
    {
      "requires_user_approval": true,
      "safe_default": "stop before shell command execution, preserve completed evidence, and ask for approval",
      "trigger": "shell command execution"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Proceed with the next workflow after V6 runtime ingestion.",
  "surfaces": [
    {
      "access_mode": "write-approved",
      "id": "repo",
      "kind": "repo",
      "locator": "."
    },
    {
      "access_mode": "read-only",
      "id": "v6-frontier",
      "kind": "artifact",
      "locator": "out/v6/v32-semantic-dogfood"
    }
  ],
  "verification": [
    {
      "claim_or_output": "V6.5 consumes only trusted V6 frontier output.",
      "evidence_required": [
        "scripts/dispatch_frontier.py --self-test",
        "out/v6.5/v32-semantic-dogfood/status.json"
      ],
      "falsifier": "A stale or tampered V6 packet can produce prepared status."
    },
    {
      "claim_or_output": "V6.5 does not execute the frontier packet.",
      "evidence_required": [
        "out/v6.5/v32-semantic-dogfood/dispatch.json",
        "out/v6.5/v32-semantic-dogfood/status.json"
      ],
      "falsifier": "The script writes worker outputs or runs a backend."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 16000,
        "must_exclude": [
          "out/**/work/"
        ],
        "must_include": [
          "scripts/ingest_worker_review.py",
          "scripts/dispatch_worker.py",
          "docs/v6.5-frontier-dispatch.workflow.plan.json"
        ]
      },
      "forbidden_actions": [
        "worker execution",
        "backend execution",
        "unsupported approval",
        "external service calls"
      ],
      "id": "frontier-dispatch-worker",
      "ownership": [
        "frontier_validation",
        "dispatch_preparation",
        "resume_verification"
      ],
      "prompt_contract": {
        "inputs": [
          "V6 run directory",
          "selected frontier packet",
          "frontier prompt"
        ],
        "required_output_schema": "dispatch.json plus packet and prompt copies",
        "stop_conditions": [
          "V6 output is not frontier-ready",
          "selected packet is stale",
          "execution would be required"
        ]
      },
      "role": "Frontier dispatch implementer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": true,
        "write": true
      }
    }
  ]
}
