{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "human-gates"
    ],
    "reason": "V102 needs one bounded live proof packet for a seeded micro task."
  },
  "assumptions": [
    {
      "claim": "The seeded workspace contains a failing pytest check.",
      "verification": "python -m pytest -q fails before the live backend runs."
    }
  ],
  "budget": {
    "file_touch_limit": "seeded workspace only",
    "max_agents": 1,
    "max_retries": 0,
    "max_rounds": 1,
    "time_box": "120 seconds"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "python -m pytest -q passes inside the seeded workspace",
      "expected_output": "a minimal code correction plus passing pytest output",
      "forbidden_actions": [
        "package manager changes",
        "external service calls",
        "credential reading",
        "release actions",
        "file removal",
        "git commit",
        "git publication",
        "git ref mutation",
        "DWM repo tracked file changes"
      ],
      "inputs": [
        "workflow.plan.json",
        "repository path",
        "fixtures/live-proof/seed"
      ],
      "instruction": "In the seeded workspace, correct the minimal arithmetic bug so the existing pytest check passes. Stay inside the seeded workspace and do not touch the DWM repository."
    },
    "mode": "runtime"
  },
  "handoffs": [
    {
      "artifact": "verification-after.txt",
      "artifact_schema": {
        "format": "test-log",
        "required_fields": [
          "pytest result"
        ],
        "validation_command": "python -m pytest -q"
      },
      "from_phase": "fix-seed",
      "to_phase": "verify"
    }
  ],
  "objective": "Make one seeded pytest task pass inside a throwaway V102 workspace.",
  "parallelism": {
    "barriers": [
      "verify after the minimal correction"
    ],
    "concurrency_cap": 1,
    "fan_in_rule": "single worker only",
    "shape": "pipeline"
  },
  "patterns": [
    "Pipeline",
    "Human Gate"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "Seeded workspace exists",
        "The preflight pytest check is red"
      ],
      "exit_criteria": [
        "The pytest check is green"
      ],
      "id": "fix-seed",
      "name": "Fix Seed",
      "outputs": [
        "verification-after.txt"
      ],
      "worker_ids": [
        "seed-fixer"
      ]
    },
    {
      "depends_on": [
        "fix-seed"
      ],
      "entry_criteria": [
        "verification-after.txt exists"
      ],
      "exit_criteria": [
        "live-proof.json records the bounded result"
      ],
      "id": "verify",
      "name": "Verify",
      "outputs": [
        "live-proof.json"
      ],
      "worker_ids": [
        "seed-fixer"
      ]
    }
  ],
  "plan_id": "v102-live-proof-1",
  "resume": {
    "cacheable_outputs": [
      "live-proof.json"
    ],
    "invalidators": [
      "seed fixture changes",
      "plan changes",
      "prompt changes"
    ],
    "restart_points": [
      "fix-seed"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before boundary escape and ask for approval",
      "trigger": "boundary escape"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Create a bounded live proof slice that fixes a failing seeded pytest task without touching DWM tracked files.",
  "surfaces": [
    {
      "access_mode": "read-only",
      "id": "seed",
      "kind": "repo",
      "locator": "fixtures/live-proof/seed"
    }
  ],
  "verification": [
    {
      "claim_or_output": "The seeded pytest check passes after the live backend runs.",
      "evidence_required": [
        "verification-before.txt",
        "verification-after.txt",
        "live-proof.json"
      ],
      "falsifier": "python -m pytest -q still fails after the backend attempt."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 5,
        "max_tokens": 4000,
        "must_exclude": [
          "out/"
        ],
        "must_include": [
          "live_math.py",
          "test_live_math.py"
        ]
      },
      "forbidden_actions": [
        "package manager changes",
        "external service calls",
        "credential reading",
        "release actions",
        "file removal",
        "git commit",
        "git publication",
        "git ref mutation",
        "DWM repo tracked file changes"
      ],
      "id": "seed-fixer",
      "ownership": [
        "seeded workspace"
      ],
      "prompt_contract": {
        "inputs": [
          "workflow.plan.json",
          "repository path",
          "fixtures/live-proof/seed"
        ],
        "required_output_schema": "passing pytest output",
        "stop_conditions": [
          "missing seed files",
          "request to leave the seeded workspace"
        ]
      },
      "role": "Seed fixer",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": false,
        "write": false
      }
    }
  ]
}
