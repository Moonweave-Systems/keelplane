{
  "activation": {
    "decision": "activate",
    "downgrade_target": null,
    "matched_thresholds": [
      "downstream-consumer",
      "planned-fanout"
    ],
    "reason": "The workflow needs a reusable first slice and downstream handoff."
  },
  "assumptions": [
    {
      "claim": "The repository path is available to the operator.",
      "verification": "The first slice records the path as an input snapshot."
    }
  ],
  "budget": {
    "file_touch_limit": "read-only inventory only",
    "max_agents": 2,
    "max_retries": 1,
    "max_rounds": 2,
    "time_box": "one planning session"
  },
  "created_by": "depone",
  "execution_path": {
    "consumer": "codex-agent",
    "first_slice": {
      "completion_check": "inventory.json validates and unresolved gaps are listed",
      "expected_output": "inventory.json with surfaces, owners, and gaps",
      "forbidden_actions": [
        "unsupported claims"
      ],
      "inputs": [
        "workflow.plan.json",
        "original prompt",
        "repository path"
      ],
      "instruction": "Inventory repository surfaces and record gaps without changing files."
    },
    "mode": "subagent-plan"
  },
  "handoffs": [
    {
      "artifact": "inventory.json",
      "artifact_schema": {
        "format": "json",
        "required_fields": [
          "surfaces",
          "owners",
          "gaps"
        ],
        "validation_command": "python -m json.tool inventory.json"
      },
      "from_phase": "inventory",
      "to_phase": "verify"
    }
  ],
  "objective": "Prepare a read-only inventory that another agent can verify.",
  "parallelism": {
    "barriers": [
      "inventory before verification"
    ],
    "concurrency_cap": 2,
    "fan_in_rule": "Fan in after the inventory validates.",
    "shape": "pipeline"
  },
  "patterns": [
    "Pipeline",
    "Human Gate"
  ],
  "phases": [
    {
      "depends_on": [],
      "entry_criteria": [
        "Repository path is available"
      ],
      "exit_criteria": [
        "inventory.json exists"
      ],
      "id": "inventory",
      "name": "Inventory",
      "outputs": [
        "inventory.json"
      ],
      "worker_ids": [
        "inventory-worker"
      ]
    },
    {
      "depends_on": [
        "inventory"
      ],
      "entry_criteria": [
        "inventory.json validates"
      ],
      "exit_criteria": [
        "verification notes are complete"
      ],
      "id": "verify",
      "name": "Verify",
      "outputs": [
        "verification.md"
      ],
      "worker_ids": [
        "verify-worker"
      ]
    }
  ],
  "plan_id": "positive-ready-readonly",
  "resume": {
    "cacheable_outputs": [
      "inventory.json",
      "verification.md"
    ],
    "invalidators": [
      "prompt changes",
      "repository path changes"
    ],
    "restart_points": [
      "inventory",
      "verify"
    ]
  },
  "risk_gates": [
    {
      "requires_user_approval": true,
      "safe_default": "stop before writing and ask for approval",
      "trigger": "manual approval boundary"
    }
  ],
  "schema_version": "0.5",
  "source_prompt": "Design a read-only workflow that inventories repository surfaces for later verification.",
  "surfaces": [
    {
      "access_mode": "read-only",
      "id": "repo",
      "kind": "repo",
      "locator": "."
    }
  ],
  "verification": [
    {
      "claim_or_output": "The inventory can be verified by a downstream agent.",
      "evidence_required": [
        "inventory.json"
      ],
      "falsifier": "A downstream agent cannot identify surfaces, owners, and gaps."
    }
  ],
  "workers": [
    {
      "context_budget": {
        "max_files": 20,
        "max_tokens": 12000,
        "must_exclude": [
          "out/"
        ],
        "must_include": [
          "workflow.plan.json"
        ]
      },
      "forbidden_actions": [
        "unsupported claims"
      ],
      "id": "inventory-worker",
      "ownership": [
        "inventory"
      ],
      "prompt_contract": {
        "inputs": [
          "workflow.plan.json",
          "repository path"
        ],
        "required_output_schema": "inventory.json",
        "stop_conditions": [
          "missing repository path"
        ]
      },
      "role": "Inventory worker",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": false,
        "write": false
      }
    },
    {
      "context_budget": {
        "max_files": 10,
        "max_tokens": 8000,
        "must_exclude": [
          "out/"
        ],
        "must_include": [
          "inventory.json"
        ]
      },
      "forbidden_actions": [
        "unsupported claims"
      ],
      "id": "verify-worker",
      "ownership": [
        "verification"
      ],
      "prompt_contract": {
        "inputs": [
          "inventory.json"
        ],
        "required_output_schema": "verification.md",
        "stop_conditions": [
          "inventory missing"
        ]
      },
      "role": "Verification worker",
      "tool_permissions": {
        "mcp_connectors": [],
        "network": false,
        "read": true,
        "requires_escalation_for": [],
        "shell": false,
        "write": false
      }
    }
  ]
}
